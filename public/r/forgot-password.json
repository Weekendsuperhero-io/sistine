{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "forgot-password",
  "title": "Forgot Password",
  "description": "Password reset form.",
  "dependencies": [
    "@phosphor-icons/react"
  ],
  "registryDependencies": [
    "@sistine/button",
    "@sistine/card",
    "@sistine/input",
    "@sistine/label"
  ],
  "files": [
    {
      "path": "components/blocks/forgot-password.tsx",
      "content": "\"use client\";\n\nimport { ArrowLeft } from \"@phosphor-icons/react\";\nimport { Button } from \"@/components/ui/button\";\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\nimport { Input } from \"@/components/ui/input\";\nimport { Label } from \"@/components/ui/label\";\n\nexport function ForgotPasswordBlock() {\n  return (\n    <div className=\"flex items-center justify-center min-h-screen p-6\">\n      <Card variant=\"glass\" className=\"w-full max-w-md text-foreground\">\n        <CardHeader className=\"space-y-1\">\n          <CardTitle className=\"text-2xl text-foreground\">Forgot password?</CardTitle>\n          <CardDescription className=\"text-muted-foreground\">\n            Enter your email address and we&apos;ll send you a link to reset your password\n          </CardDescription>\n        </CardHeader>\n        <CardContent className=\"space-y-4\">\n          <div className=\"space-y-2\">\n            <Label htmlFor=\"email\" className=\"text-foreground\">\n              Email\n            </Label>\n            <Input\n              id=\"email\"\n              type=\"email\"\n              placeholder=\"name@example.com\"\n              variant=\"glass\"\n              className=\"text-foreground placeholder:text-muted-foreground\"\n            />\n          </div>\n          <Button variant=\"glass\" className=\"w-full text-foreground\">\n            Send Reset Link\n          </Button>\n          <Button variant=\"link\" className=\"w-full text-muted-foreground\" asChild>\n            <a href=\"/authentication\">\n              <ArrowLeft className=\"mr-2 h-4 w-4\" />\n              Back to sign in\n            </a>\n          </Button>\n        </CardContent>\n      </Card>\n    </div>\n  );\n}\n",
      "type": "registry:component",
      "target": "components/blocks/forgot-password.tsx"
    }
  ],
  "type": "registry:block"
}